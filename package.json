{
  "name": "lumina-quest",
  "private": true,
  "version": "0.1.0",
  "description": "LuminaQuest turn-based story engine",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev -w server & npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web",
    "test:server": "npm run test -w server",
    "start": "npm run start -w server",
    "mongo:up": "docker compose up -d mongo",
    "mongo:down": "docker compose stop mongo",
    "mongo:logs": "docker compose logs -f mongo"
  }
}
